---
import type { Project } from '../types/project';
import cardBg from '../assets/card-bg.jpg';
import cardBg5 from '../assets/card-bg-5.jpg';
import cardBg6 from '../assets/card-bg-6.jpg';
import cardBg7 from '../assets/card-bg-7.jpg';

type Props = Project;

const { title, subtitle, content, link, tags, status, id }: Props = Astro.props;
---

<div class="card">
    <div class="card__content">
        <div class="card__front" style={`background-image: url(${id === 'agarsteget' ? cardBg5.src : id === 'coompass' ? cardBg6.src : id === 'around' ? cardBg7.src : cardBg.src}); background-size: cover; background-blend-mode: overlay; background-color: #b7c9e5;`}>
            <h3 class="card__title">{title}</h3>
            <p class="card__subtitle">{subtitle}</p>
        </div>

        <div class="card__back">
            
            <p class="card__body">{content}</p>
            <div class="card__tags">
                {tags.map((tag: string) => (
                    <span class="card__tag">{tag}</span>
                ))}
            </div>
            <div class="card__footer">
                <a class="card__link" href={link} target="_blank">View Project_</a>
                <span class:list={[
                    "status-badge",
                    { prod: status === 'production' }, 
                    { mvp: status === 'mvp' }, 
                    { dev: status === 'development' }, 
                ]}>{status}</span>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        width: 400px;
        cursor: crosshair;
    }

    .card__content {
        text-align: center;
        position: relative;
        padding: 15em 5em;
        transition: transform 2s;
        transform-style: preserve-3d;
    }

    .card:hover .card__content {
        transform: rotateY(.5turn) ;
    }

    .card__front,
    .card__back {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        padding: 5em 3em;
        backface-visibility: hidden;
        transform-style: preserve-3d;
        display: grid;
        align-content: center;
    }

    .card__front {
        background-color: var(--clr-white);
        color: var(--clr-black);
    }

    .card__front::before {
        content: '';
        position: absolute;
        --spacer: 1em;
        top: var(--spacer);
        left: var(--spacer);
        right: var(--spacer);
        bottom: var(--spacer);
        border: 3px solid currentColor;
        transform: var(--level-one);
    }

    .card__title {
        font-size: var(--heading-sm);
        transform: var(--level-three);
        order: 2;
        text-transform: uppercase;
    }

    .card__subtitle {
        transform: var(--level-two);
        text-transform: uppercase;
        letter-spacing: 4px;
        font-size: var(--text-xs);
        font-weight: var(--fw-bold);
        padding-bottom: .5em;
        opacity: .7;
    }

    .card__body {
        text-align: left;
        color: var(--clr-brand-100);
        transform: var(--level-two);
        font-family: var(--ff-sans);
        font-weight: var(--fw-medium);
        font-size: var(--text-md);
        line-height: 1.6;
    }

    .card__back {
        transform: rotateY(.5turn);
        color: var(--clr-white);
        background: var(--clr-neutral-900);
    }

    .card__tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5em;
        padding: 1em 0;
        transform: var(--level-one);
    }

    .card__tag {
        font-size: var(--text-xs);
        font-family: var(--ff-sans);
        font-weight: 500;
        border: 1px solid var(--clr-amber-500);
        border-radius: 4px;
        padding: 0.25em 0.5em;
    }

    .card__footer {
        margin-top: 2em;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transform: var(--level-two);
    }

    .card__link {
        width: fit-content;
        font-family: var(--ff-mono);
        font-size: var(--text-xs);
        text-transform: uppercase;
        letter-spacing: 0.2em;
        text-decoration: none;
        color: var(--clr-high-contrast);
        transition: color 0.25s ease-in-out;
    }

    .card__link:hover {
        color: var(--clr-brand-500);
    }

    .status-badge {
        position: relative;
        font-family: var(--ff-mono);
        font-size: var(--text-xs);
        font-weight: var(--fw-medium);
        padding: 0.25rem 0.5rem;
        border-radius: var(--border-radius-3);
        color: var(--clr-black);
    }

    .prod {
        background-color: var(--clr-green-100);
        border: 1px solid var(--clr-green-500);
    }

    .status-badge.prod::after,
    .status-badge.prod::before {
        content: '';
        position: absolute;
        width: calc(100% + 6px);
        height: calc(100% + 6px);
        background-image: conic-gradient(var(--clr-green-500), var(--clr-brand-500), var(--clr-sky-500), var(--clr-green-500));
        top: 50%;
        left: 50%;
        translate: -50% -50%;
        z-index: -1;
        border-radius: var(--border-radius-4);
    }

    .status-badge.prod::before {
        filter: blur(1rem);
        opacity: 0.5;
    }

    .mvp {
        background-color: var(--clr-brand-100);
        border: 1px solid var(--clr-brand-500);
    }

    .dev {
        background-color: var(--clr-sky-100);
        border: 1px solid var(--clr-sky-500);
    }
</style>

