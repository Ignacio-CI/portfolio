---
const { href, openInNewTab = false } = Astro.props;
---

<a href={href} target={openInNewTab ? '_blank' : '_self'}>
    <slot />
</a>

<style>
    a {
        font-family: var(--ff-mono);
        font-size: var(--text-xs);
        color: var(--clr-black);
        font-weight: 500;
        text-decoration: none;
        text-transform: lowercase;
    }

    a:hover,
    a:focus-visible {
        color: var(--text-accent);
    }
</style>
