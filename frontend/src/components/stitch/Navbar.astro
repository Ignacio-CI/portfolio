---
// Navbar.astro
---
<nav class="fixed top-0 w-full z-50 bg-black/40 backdrop-blur-xl border-none bg-linear-to-b from-black/80 to-transparent shadow-[0_0_40px_rgba(204,151,255,0.05)]">
    <div class="flex justify-between items-center px-8 py-6 max-w-7xl mx-auto">
        <div class="text-2xl font-bold tracking-tighter text-white font-headline">Ignace.dev</div>
        <!-- Desktop Navigation -->
        <div class="hidden md:flex items-center space-x-12 font-headline tracking-tight">
            <a class="text-primary font-bold border-b-2 border-primary pb-1" href="#">Services</a>
            <a class="text-zinc-400 hover:text-secondary transition-all duration-300" href="#">Projects</a>
            <a class="text-zinc-400 hover:text-secondary transition-all duration-300" href="#">Process</a>
            <a class="text-zinc-400 hover:text-secondary transition-all duration-300" href="#">About</a>
        </div>
        <div class="flex items-center space-x-6">
            <button class="hidden md:block text-zinc-400 hover:text-white font-label text-[10px] uppercase tracking-widest transition-colors">Login</button>
            <button class="bg-linear-to-r from-primary to-primary-dim text-on-primary-fixed px-6 py-2.5 rounded-md font-bold text-sm hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20">
                Start Project
            </button>
        </div>
    </div>
</nav>
