---
// Services.astro
---
<section class="py-32 relative bg-surface-container-lowest">
    <div class="max-w-7xl mx-auto px-8">
        <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
            <div class="max-w-xl">
                <h2 class="font-label text-[10px] uppercase tracking-[0.4em] text-primary mb-4">Core Capabilities</h2>
                <h3 class="font-headline text-4xl md:text-6xl font-bold text-white tracking-tighter">Engineered for the future.</h3>
            </div>
            <div class="text-on-surface-variant font-label text-[10px] uppercase tracking-widest border-l border-outline-variant/30 pl-8 pb-2">
                01 / Services
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
            <!-- Large Featured Service -->
            <div class="md:col-span-8 group relative overflow-hidden rounded-xl bg-surface-container-low p-12 hover:bg-surface-container transition-colors duration-500">
                <div class="relative z-10">
                    <span class="material-symbols-outlined text-4xl text-primary mb-8" data-icon="terminal">terminal</span>
                    <h4 class="font-headline text-3xl font-bold text-white mb-4">AI-Driven Web Applications</h4>
                    <p class="text-on-surface-variant max-w-md leading-relaxed font-body">
                        From conversion-optimized landing pages to complex enterprise platforms. Strategic human design meets high-speed agent execution for robust, scalable growth.
                    </p>
                </div>
                <div class="absolute top-0 right-0 w-96 h-96 opacity-10 group-hover:opacity-20 transition-opacity">
                    <img class="w-full h-full object-cover" data-alt="Abstract glowing code network pattern" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBTbaNSlSujaNj_RYfmIVr0CqIpjhBhigryvYOzis5ut_TYTqR72IZR1lYVEguTIemjUBZWiQBYTlBEaQ7RClu-pcLiIIERYb3wpgeHH5_w5n0oVYvdDmvQbZCquXpjBuUAp4JOfVNB63TQ8vkEdMwNsq6DUy0GJAYua9x3bRKOQiWG137mO2qE1oEfsGLBbFd3wMoK3bMRPbL9lfP3cId7cr5n1NnNJ--3zUMZCUUpELbDfG8TnVyNESF2Bu7wAhrU7SQ0YdPmasI8"/>
                </div>
            </div>

            <!-- Secondary Service -->
            <div class="md:col-span-4 group bg-surface-container-low p-12 rounded-xl border border-outline-variant/10 hover:border-secondary/30 transition-all">
                <span class="material-symbols-outlined text-4xl text-secondary mb-8" data-icon="memory">memory</span>
                <h4 class="font-headline text-2xl font-bold text-white mb-4">Strategic Automation</h4>
                <p class="text-on-surface-variant leading-relaxed font-body">
                    We architect custom AI Agent Swarms to automate your unique business workflows with expert precision.
                </p>
            </div>

            <!-- Service Row 2 -->
            <div class="md:col-span-4 group bg-surface-container-low p-12 rounded-xl border border-outline-variant/10 transition-all">
                <span class="material-symbols-outlined text-4xl text-tertiary mb-8" data-icon="query_stats">query_stats</span>
                <h4 class="font-headline text-2xl font-bold text-white mb-4">Intelligent Data Ecosystems</h4>
                <p class="text-on-surface-variant leading-relaxed font-body">
                    Custom RAG pipelines and knowledge systems designed by strategy and powered by AI.
                </p>
            </div>

            <div class="md:col-span-8 group bg-surface-container-low p-12 rounded-xl border border-outline-variant/10 flex flex-col md:flex-row items-center gap-12 hover:bg-surface-container transition-colors">
                <div class="flex-1">
                    <span class="material-symbols-outlined text-4xl text-primary mb-8" data-icon="cloud_done">cloud_done</span>
                    <h4 class="font-headline text-2xl font-bold text-white mb-4">Custom AI Architectures</h4>
                    <p class="text-on-surface-variant leading-relaxed font-body">
                        Bespoke MCP server development and cloud integrations that bridge the gap between your data and next-gen intelligence.
                    </p>
                </div>
                <div class="w-full md:w-64 h-32 glass-panel rounded-lg flex items-center justify-center">
                    <span class="text-[10px] font-label tracking-[0.3em] uppercase opacity-40">Network Ready</span>
                </div>
            </div>
        </div>
    </div>
</section>
