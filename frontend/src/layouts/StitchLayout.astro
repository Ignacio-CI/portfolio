---
import '../styles/global.css';

import Navbar from '../components/stitch/Navbar.astro';
import Footer from '../components/stitch/Footer.astro';

const { title = 'Ignace.dev — The Digital Architect' } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        
        <!-- Fonts from Stitch Design -->
        <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Manrope:wght@300;400;500;600;700&family=Inter:wght@400;500;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    </head>
    <body class="bg-background text-on-surface font-body selection:bg-secondary selection:text-on-secondary min-h-screen flex flex-col">
        <Navbar />
        <main class="grow">
            <slot />
        </main>
        <Footer />
    </body>
</html>
