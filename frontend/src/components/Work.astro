---
import ProjectCardContainer from "@components/ProjectCardContainer.astro";
import Section from "@layouts/Section.astro";
import projects from "@data/projects.json" assert { type: "json" };
---

<Section id="work">
    <article class="projects__wrapper">
        <div class="projects__header">
            <h1>WORK</h1>
            <p>Some of the projects that I've been working on</p>
        </div>
        <ProjectCardContainer projects={projects} />
    </article>
</Section>

<style>
    .projects__wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: var(--gap-4);
    }

    .projects__header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: var(--gap-2);
        padding: 1em;
    }

    .projects__header h1 {
        font-size: var(--text-2xl);
        font-weight: 700;
        margin: 0;
    }

    .projects__header p {
        font-family: var(--ff-mono);
        font-size: var(--text-sm);
        color: var(--text-muted);
        margin: 0;
    }
</style>
