---
// Projects.astro
---
<section class="py-32 relative bg-surface-dim">
    <div class="max-w-7xl mx-auto px-8">
        <div class="flex justify-between items-end mb-16">
            <h3 class="font-headline text-4xl font-bold text-white tracking-tighter">Selected Prototypes</h3>
            <a class="text-secondary font-label text-[10px] uppercase tracking-widest flex items-center gap-2 group" href="#">
                View Archive 
                <span class="material-symbols-outlined text-sm transition-transform group-hover:translate-x-1" data-icon="arrow_forward">arrow_forward</span>
            </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            <!-- Project 1 -->
            <div class="group cursor-pointer">
                <div class="relative aspect-16/10 overflow-hidden rounded-xl bg-surface-container mb-6">
                    <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 grayscale group-hover:grayscale-0 opacity-60 group-hover:opacity-100" data-alt="Dark futuristic interface design mockup" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAlPfyThO7H-9k7_AShfIdsG6oIl4rawgB4JT5m4uzn5JO4P_Sy4mgmCtTwgtLzGrWF15XHcpKLg3Lgo8VMLgMy9mZziBxfgyJMzUREfPPHfcw6ZSsbjT6IXnX2Rdt2CmO3wkdv5-j9xKfmQZCBc1qtoWIyRj_5Yx3uvUq2s0EFjhSM0-sNZ9g91I3pfhLg2eTLCqOFvM2Aand-Y6e-L4g1xKSgVObRe83_vRTCMdRgAxuu5eJ60d125knIDVXYpPfaOzVxdoGQnFbq"/>
                    <div class="absolute inset-0 bg-linear-to-t from-black via-transparent to-transparent opacity-60"></div>
                    <div class="absolute bottom-6 left-6">
                        <span class="text-[10px] font-label uppercase tracking-widest text-primary bg-black/80 px-3 py-1 rounded">2024</span>
                    </div>
                </div>
                <h4 class="font-headline text-2xl font-bold text-white mb-2">Aether OS</h4>
                <p class="text-on-surface-variant font-body">Next-gen desktop environment for AI researchers.</p>
            </div>

            <!-- Project 2 -->
            <div class="group cursor-pointer">
                <div class="relative aspect-16/10 overflow-hidden rounded-xl bg-surface-container mb-6">
                    <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 grayscale group-hover:grayscale-0 opacity-60 group-hover:opacity-100" data-alt="Abstract 3D digital data visualization" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA_gnqsaHx6ReeZ9cTkSOlNqKJD57CMiJEw6qdCQwqmqPZ3ULeAkB-n9-9KTjdBeE-AeM0rm2RxC-YxhNvxfn0u8g2QL_ienme7i3MtWndqh1ks7__urJ4gK4ciVZsoJw0lQeSHevUTxaiZBia-cSLUc_hInhsjNrWwNzo1GDMBaCxEXEQMIoj0MgjcIQCLvIHeV1Qm-ZVqlXZRS2nGhYKL1eCb5i7NRk58aX09FSpHLa7GzLu0iU66H9XSl_QsUn4FxRvQnzggBqdI"/>
                    <div class="absolute inset-0 bg-linear-to-t from-black via-transparent to-transparent opacity-60"></div>
                    <div class="absolute bottom-6 left-6">
                        <span class="text-[10px] font-label uppercase tracking-widest text-secondary bg-black/80 px-3 py-1 rounded">2023</span>
                    </div>
                </div>
                <h4 class="font-headline text-2xl font-bold text-white mb-2">Lumina Protocol</h4>
                <p class="text-on-surface-variant font-body">Decentralized data mesh for neural networks.</p>
            </div>
        </div>
    </div>
</section>
