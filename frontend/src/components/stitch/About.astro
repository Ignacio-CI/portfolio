---
import Me from '@assets/me-3.png';
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import TerminalChat from './TerminalChat.svelte';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="about" class="pt-32 pb-24 px-8 md:px-16 lg:px-32 max-w-[1600px] mx-auto overflow-hidden">
    <!-- Section 1: The Architect's Persona -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center mb-32">
        <div class="lg:col-span-5 relative group">
            <div
                class="absolute -inset-4 bg-primary/10 blur-3xl rounded-full opacity-20 group-hover:opacity-40 transition-opacity duration-700"
            >
            </div>
            <div
                class="relative overflow-hidden rounded-xl border border-outline-variant/15 aspect-4/5 bg-surface-container-low"
            >
                <img
                    class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-1000 scale-105 group-hover:scale-100"
                    alt="Professional portrait of Ignace in high-contrast dramatic lighting"
                    src={Me.src}
                />
                <div class="absolute inset-0 bg-linear-to-t from-background via-transparent to-transparent opacity-60">
                </div>
            </div>
            <div class="absolute -bottom-6 -right-6 hidden lg:block">
                <div
                    class="glass-panel p-6 rounded-xl border border-primary/20 shadow-[0_0_80px_rgba(168,85,247,0.05)]"
                >
                    <p class="font-label text-[10px] uppercase tracking-[0.2em] text-primary mb-1">{t('about.profile.role')}</p>
                    <p class="font-headline font-bold text-white uppercase text-lg tracking-tighter">Ignacio Cerda</p>
                </div>
            </div>
        </div>
        <div class="lg:col-span-7 space-y-8">
            <div class="space-y-2">
                <span class="font-label text-[10px] uppercase tracking-[0.4em] text-secondary font-semibold"
                    >{t('about.profile.badge')}</span
                >
                <h2 class="text-6xl md:text-8xl font-headline font-bold tracking-tighter leading-[0.9] text-white" set:html={t('about.profile.title')}>
                </h2>
            </div>
            <div class="max-w-xl space-y-6">
                <p class="text-xl md:text-2xl font-body text-on-surface font-light leading-relaxed">
                    {t('about.profile.p1')}
                </p>
                <p class="text-on-surface-variant font-body leading-relaxed border-l border-primary/30 pl-6">
                    {t('about.profile.p2')}
                </p>
            </div>
        </div>
    </div>

    <!-- Section 2: AI Interactive Terminal -->
    <div class="mb-48 relative">
        <div
            class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-secondary/5 blur-[120px] rounded-full pointer-events-none"
        >
        </div>
        <div class="max-w-5xl mx-auto relative z-10">
            <div class="mb-12 text-center">
                <h3 class="font-headline text-4xl font-bold tracking-tight mb-4 uppercase text-white">
                    {t('about.terminal.title')}
                </h3>
                <p class="font-label text-xs uppercase tracking-widest text-on-surface-variant">
                    {t('about.terminal.subtitle')}
                </p>
            </div>
            <TerminalChat
                client:visible
                terminalHeader={t('about.terminal.header')}
                aiInitialBody={t('about.terminal.ai.body')}
                visitorLabel="visitor@ignace:~$"
            />
        </div>
    </div>

    <!-- Section 3: Core Principles Grid (Asymmetric Bento) -->
    <div class="mb-32">
        <div class="mb-16 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="max-w-md">
                <h3 class="font-headline text-5xl font-bold tracking-tighter uppercase mb-4 text-white" set:html={t('about.foundations.title')}>
                </h3>
                <p class="text-on-surface-variant text-sm font-body">
                    {t('about.foundations.subtitle')}
                </p>
            </div>
            <div class="h-px bg-outline-variant/20 grow mx-8 hidden md:block mb-4"></div>
            <div class="font-label text-[10px] uppercase tracking-[0.5em] text-outline mb-4 shrink-0">
                {t('about.foundations.standards')} // {new Date().getFullYear()}
            </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
            <!-- Card 1 -->
            <div class="md:col-span-8 group relative md:h-[400px]">
                <div
                    class="absolute inset-0 bg-linear-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-xl"
                >
                </div>
                <div
                    class="h-full min-h-[300px] glass-panel p-6 md:p-10 flex flex-col justify-between rounded-xl border border-outline-variant/15"
                >
                    <Icon name="material-symbols:precision-manufacturing" class="text-primary text-5xl" />
                    <div>
                        <h4 class="font-headline text-3xl font-bold text-white mb-4 uppercase tracking-tighter">
                            {t('about.f1.title')}
                        </h4>
                        <p class="text-on-surface-variant font-body leading-relaxed max-w-lg">
                            {t('about.f1.desc')}
                        </p>
                    </div>
                </div>
            </div>
            <!-- Card 2 -->
            <div class="md:col-span-4 group min-h-[280px] md:h-[400px]">
                <div
                    class="h-full bg-surface-container-low p-6 md:p-10 flex flex-col justify-between rounded-xl border border-outline-variant/10 hover:bg-surface-container-high transition-colors"
                >
                    <Icon name="material-symbols:energy-program-saving" class="text-secondary text-5xl" />
                    <div>
                        <h4 class="font-headline text-2xl font-bold text-white mb-4 uppercase tracking-tighter">
                            {t('about.f2.title')}
                        </h4>
                        <p class="text-on-surface-variant text-sm font-body leading-relaxed">
                            {t('about.f2.desc')}
                        </p>
                    </div>
                </div>
            </div>
            <!-- Card 3 -->
            <div class="md:col-span-4 group min-h-[280px] md:h-[400px]">
                <div
                    class="h-full bg-surface-container-low p-6 md:p-10 flex flex-col justify-between rounded-xl border border-outline-variant/10 hover:bg-surface-container-high transition-colors"
                >
                    <Icon name="material-symbols:architecture" class="text-on-surface-variant text-5xl" />
                    <div>
                        <h4 class="font-headline text-2xl font-bold text-white mb-4 uppercase tracking-tighter">
                            {t('about.f3.title')}
                        </h4>
                        <p class="text-on-surface-variant text-sm font-body leading-relaxed">
                            {t('about.f3.desc')}
                        </p>
                    </div>
                </div>
            </div>
            <!-- Card 4 -->
            <div class="md:col-span-8 group min-h-[280px] md:h-[400px]">
                <div class="h-full relative overflow-hidden rounded-xl border border-outline-variant/15">
                    <img
                        class="absolute inset-0 w-full h-full object-cover grayscale opacity-40 group-hover:scale-110 transition-transform duration-1000"
                        alt="Abstract deep purple and black organic mesh pattern"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuAxlGOIyklxQP2bcGvhPeNsNhZuXMBST_3bK1jEAgFYp_GQnOvywaSk_edf3sy23qNSkC9gDIrjbQ6IPHXnwz7o3izIOSCU3gQLvKerjTMmn0rt06jkYjafyceRM27aF2k00PKSdu2mk2Bm9gMT0D1N4sYtPGEmvZ8L9G-ytnMMVYuuY4J8CjX-VkyySQJzf_L9bKXLnhZQ7MAOmJVTFIJSjSk53656imfjnREb5iRuE3UWyp_eFVfhVra3Xx-CEbyhJEhOgysl9Q8E"
                    />
                    <div
                        class="absolute inset-0 bg-linear-to-r from-black via-black/60 to-transparent p-10 flex flex-col justify-between"
                    >
                        <Icon name="material-symbols:schema" class="text-primary-dim text-5xl" />
                        <div>
                            <h4 class="font-headline text-3xl font-bold text-white mb-4 uppercase tracking-tighter">
                                {t('about.f4.title')}
                            </h4>
                            <p class="text-on-surface-variant font-body leading-relaxed max-w-md">
                                {t('about.f4.desc')}
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
