---
import Link from "@components/Link.astro";
---

<nav>
    <div class="brand">
        <span class="logo-i">I</span>
    </div>
    <ul class="nav-links">
        <li><Link href="/">The Void</Link></li>
        <li><Link href="#work">Work</Link></li>
        <li><Link href="#about">About</Link></li>
        <li><Link href="#contact">Contact</Link></li>
    </ul>
</nav>

<style>
    nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5em 2em;
        border-bottom: 0.5px solid var(--ui-border);
        backdrop-filter: blur(10px);
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: var(--gap-3);
    }

    .logo-i {
        font-family: var(--ff-mono);
        background: var(--clr-black);
        color: var(--clr-white);
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: var(--text-xs);
    }

    .nav-links {
        display: flex;
        list-style: none;
        gap: 2rem;
        margin: 0;
        padding: 0;
    }

    @media (width <= 760px) {
        nav {
            padding: 1em 1.25em;
        }

        .nav-links {
            gap: 1rem;
            font-size: var(--text-xs);
        }
    }

    nav.nav--on-dark {
        --link-color: var(--text-high-contrast);
    }

    nav.nav--on-dark .logo-i {
        color: var(--text-high-contrast);
        border-color: var(--text-high-contrast);
    }
</style>

<script>
    const nav = document.querySelector('nav');
    const darkSections = document.querySelectorAll('#about, #contact');

    const observer = new IntersectionObserver(
        () => {
            const anyVisible = [...darkSections].some(el =>
                el.getBoundingClientRect().top < 60 &&
                el.getBoundingClientRect().bottom > 0
            );
            nav.classList.toggle('nav--on-dark', anyVisible);
        },
        { threshold: [0, 0.1, 0.9, 1], rootMargin: '0px 0px -90% 0px' }
    );

    darkSections.forEach(s => observer.observe(s));
</script>