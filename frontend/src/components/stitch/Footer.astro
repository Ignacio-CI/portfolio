---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
---
<footer class="w-full border-t border-zinc-800/50 bg-black">
    <div class="flex flex-col md:flex-row justify-between items-center px-8 py-12 space-y-4 md:space-y-0 max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row items-center gap-8">
            <div class="text-lg font-black text-white font-headline">Ignace.dev</div>
            <p class="font-label uppercase text-[10px] tracking-[0.05em] text-zinc-500">
                © 2026 Ignace.dev — {t('footer.tagline')}
            </p>
        </div>
        <div class="flex items-center space-x-8 font-label uppercase text-[10px] tracking-[0.05em]">
            <a class="text-zinc-500 hover:text-secondary transition-colors hover:-translate-y-0.5" href="#">{t('footer.privacy')}</a>
            <a class="text-zinc-500 hover:text-secondary transition-colors hover:-translate-y-0.5" href="#">{t('footer.terms')}</a>
            <a class="text-zinc-500 hover:text-secondary transition-colors hover:-translate-y-0.5" href="#">Twitter</a>
            <a class="text-zinc-500 hover:text-secondary transition-colors hover:-translate-y-0.5" href="#">LinkedIn</a>
            <a class="text-zinc-500 hover:text-secondary transition-colors hover:-translate-y-0.5" href="#">GitHub</a>
        </div>
    </div>
</footer>
