---
interface Props {
    id: string;
    bgColor?: string;
}

const { id } = Astro.props;
---

<section class="section__wrapper" id={id}>
    <slot />
</section>

<style>
    .section__wrapper {
        height: 100vh;
        width: 100vw;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>
