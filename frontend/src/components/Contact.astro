---
import Section from "@layouts/Section.astro";
---

<Section id="contact">
    <article class="contact__wrapper">
        <div class="contact__header">
            <p class="contact__label">[ get in touch ]</p>
            <h1 class="contact__heading">CONTACT</h1>
            <p class="contact__sub">Let's build something together.</p>
        </div>
        <div class="contact__links">
            <a href="mailto:hello@ignace.dev" class="contact__link"
                >hi@ignace.dev</a
            >
            <a
                href="https://github.com/ignace"
                class="contact__link"
                target="_blank"
                rel="noopener">github/ignace</a
            >
            <a
                href="https://linkedin.com/in/ignace"
                class="contact__link"
                target="_blank"
                rel="noopener">linkedin/ignace</a
            >
        </div>
    </article>
</Section>

<style>
    .contact__wrapper {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 3rem;
        isolation: isolate;
        padding: 6rem 2rem;
    }

    .contact__header {
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .contact__label {
        font-family: var(--ff-mono);
        font-size: var(--text-xs);
        color: var(--clr-brand-600);
        letter-spacing: 0.1em;
    }

    .contact__heading {
        font-size: clamp(2.5rem, 8vw, 5rem);
        font-weight: 700;
        letter-spacing: -0.05em;
        line-height: 1;
        color: var(--text-black);
    }

    .contact__sub {
        font-family: var(--ff-mono);
        font-size: var(--text-sm);
        color: var(--clr-neutral-500);
    }

    .contact__links {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        align-items: flex-start;
    }

    .contact__link {
        font-family: var(--ff-mono);
        font-size: var(--text-lg);
        color: var(--text-black);
        text-decoration: none;
        border-left: 2px solid transparent;
        padding-left: 1rem;
        transition:
            border-color 0.2s,
            transform 0.2s,
            color 0.2s;
        display: block;
    }

    .contact__link:hover {
        border-left-color: var(--clr-brand-600);
        transform: translateX(6px);
        color: var(--clr-brand-400);
    }

    @media (width <= 760px) {
        .contact__link {
            font-size: var(--text-md);
        }
    }
</style>
