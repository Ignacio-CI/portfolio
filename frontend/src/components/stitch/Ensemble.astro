---

<!-- Hero Section: The Hive Mind -->
<section class="max-w-7xl mx-auto px-8 mb-22 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center xl:pt-16">
    <div class="lg:col-span-7">
        <h1
            class="font-headline text-[3.5rem] md:text-[5rem] leading-[0.95] font-bold tracking-[-0.02em] uppercase mb-8"
            set:html={t('ensemble.hero.title')}
        >
        </h1>
        <p class="font-body text-lg text-on-surface-variant max-w-xl leading-relaxed">
            {t('ensemble.hero.subtitle')}
        </p>
    </div>
    <div
        class="lg:col-span-5 h-[400px] relative rounded-xl overflow-hidden bg-surface-container-low neural-hub-gradient border border-outline-variant/10"
    >
        <div class="absolute inset-0 backdrop-blur-xl flex items-center justify-center p-12">
            <div class="text-center">
                <div
                    class="w-24 h-24 rounded-full border border-primary/20 flex items-center justify-center mb-6 mx-auto relative"
                >
                    <div class="absolute inset-0 rounded-full animate-pulse bg-primary/5"></div>
                    <span class="material-symbols-outlined text-primary text-4xl" data-icon="hub">hub</span>
                </div>
                <div class="font-label text-[10px] tracking-widest text-secondary uppercase mb-2">
                    {t('ensemble.hub.label')}
                </div>
                <div class="font-headline text-2xl text-white font-bold tracking-tight">{t('ensemble.hub.status')}</div>
            </div>
        </div>
    </div>
</section>

<!-- Architect Profile (Ignacio) -->
<section class="max-w-7xl mx-auto px-8 mb-22">
    <div class="p-12 bg-surface-container-low ghost-border rounded-xl flex flex-col md:flex-row gap-12 items-center">
        <div
            class="w-48 h-48 rounded-lg overflow-hidden shrink-0 grayscale hover:grayscale-0 transition-all duration-500"
        >
            <img
                alt="Ignacio"
                class="w-full h-full object-cover"
                data-alt="Close-up portrait of a visionary digital architect in dark minimalist studio with dramatic cool lighting and subtle tech overlays"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuD08GDy1r5h05-9Nt7a6eiWXoKGv8U6HRquIBeIVKE4N8QaY5fUmnRGMILfGufVNCpSRu2eIijjDRB2TfB4F2AQ1ciV2QXInfWAl_0EmtZIS0qlvrimZf2h9FDLhPyC9KsKOZ9gn4PVS-NWkaeolfOWMbFnb8mVDwLAIa9hnV6yOxsjtzPbx629ixAmAzNWhY-gemGV9NdTPOfNLYdxMe5kAZvvEoK_f-DUsqScIM2bZSGDOfY1E72L2zmerKXJvaXd4jjFQ6WCKzpi"
            />
        </div>
        <div class="grow">
            <div class="flex items-center gap-4 mb-4">
                <span
                    class="font-label text-[10px] tracking-widest text-secondary uppercase bg-secondary/10 px-3 py-1 rounded-full"
                    >{t('ensemble.ignacio.badge')}</span
                >
                <div class="h-px grow bg-outline-variant/20"></div>
            </div>
            <h2 class="font-headline text-4xl font-bold mb-4">Ignacio J.</h2>
            <p class="font-body text-on-surface-variant text-lg max-w-3xl mb-8 leading-relaxed">
                {t('ensemble.ignacio.desc')}
            </p>
            <div class="flex flex-wrap gap-8">
                <div>
                    <div class="font-label text-[10px] tracking-widest text-zinc-600 uppercase mb-1">{t('ensemble.ignacio.expertise.label')}</div>
                    <div class="font-headline text-white font-medium">{t('ensemble.ignacio.expertise.value')}</div>
                </div>
                <div>
                    <div class="font-label text-[10px] tracking-widest text-zinc-600 uppercase mb-1">{t('ensemble.ignacio.focus.label')}</div>
                    <div class="font-headline text-white font-medium">{t('ensemble.ignacio.focus.value')}</div>
                </div>
                <div>
                    <div class="font-label text-[10px] tracking-widest text-zinc-600 uppercase mb-1">{t('ensemble.ignacio.location.label')}</div>
                    <div class="font-headline text-white font-medium">{t('ensemble.ignacio.location.value')}</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Agent Grid (8 Nodes) -->
<section class="max-w-7xl mx-auto px-8 mb-22">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
            agents.map((agent) => (
                <div class="group relative overflow-hidden bg-surface-container-lowest p-8 rounded-lg card-glow hover:bg-surface-variant transition-all duration-300 border border-transparent hover:border-outline-variant/10 hover:cursor-crosshair">
                    <div
                        class="absolute inset-0 bg-center bg-cover opacity-10 group-hover:opacity-40 group-hover:scale-105 transition-all duration-500"
                        style={`background-image: url('${agent.image}')`}
                    />
                    <div class="relative z-10">
                        <span
                            class="material-symbols-outlined text-secondary mb-6 block drop-shadow-[0_0_8px_rgba(83,221,252,0.5)]"
                            data-icon={agent.icon}
                        >
                            {agent.icon}
                        </span>
                        <h3 class="font-headline text-2xl font-bold mb-2 drop-shadow-md">{agent.title}</h3>
                        <div class="font-label text-[10px] tracking-widest text-secondary uppercase mb-6 drop-shadow-sm">
                            {agent.subtitle}
                        </div>
                        <ul class="font-label text-[10px] tracking-widest text-zinc-400 uppercase space-y-2 drop-shadow-sm">
                            <li>{t('ensemble.agents.role')}: {agent.role}</li>
                            <li>{t('ensemble.agents.skills')}: {agent.skills}</li>
                        </ul>
                    </div>
                </div>
            ))
        }
    </div>
</section>

<!-- CTA Section -->
<section class="max-w-7xl mx-auto px-8 mb-22 py-24 text-center bg-surface-dim rounded-xl">
    <h2 class="font-headline text-[3.5rem] font-bold tracking-tight mb-8">{t('ensemble.cta.title')}</h2>
    <p class="font-body text-on-surface-variant max-w-2xl mx-auto mb-12">
        {t('ensemble.cta.subtitle')}
    </p>
    <button
        class="bg-linear-to-r from-primary to-primary-dim text-on-primary px-12 py-4 rounded-lg font-bold text-lg cursor-pointer hover:scale-95 hover:opacity-90 transition-all"
    >
        {t('ensemble.cta.btn')}
    </button>
</section>

<style is:global>
    .material-symbols-outlined {
        font-variation-settings:
            'wght' 100,
            'opsz' 24;
        font-size: 20px;
    }
    .neural-hub-gradient {
        background: radial-gradient(
            circle at 50% 50%,
            rgba(204, 151, 255, 0.15),
            rgba(83, 221, 252, 0.1),
            transparent 70%
        );
    }
    .ghost-border {
        box-shadow: inset 0 0 0 1px rgba(73, 72, 71, 0.15);
    }
    .card-glow:hover {
        box-shadow: -10px -10px 40px -5px rgba(204, 151, 255, 0.1);
    }
</style>
